{
  "rootLayout": {
    "titleDefault": "{{appName}} — Amazon Pazar Analizi",
    "titleTemplate": "%s | {{appName}}"
  },
  "brand": {
    "appName": "MarketPulse",
    "taglineTr": "Amazon'da doğru kategoriye gir",
    "taglineEn": "Enter the right Amazon category",
    "wordMarkLine1": "{{appName}}",
    "wordMarkLine2": "",
    "shortName": "{{appName}}",
    "copyrightHolder": "{{appName}}",
    "defaultLogoAlt": "{{appName}} logo"
  },
  "site": {
    "originFallback": "http://localhost:3077",
    "apiBaseFallback": "http://127.0.0.1:8086/api/v1"
  },
  "i18n": {
    "defaultLocale": "tr"
  },
  "seo": {
    "global": {
      "site_name": "{{appName}}",
      "title_default": "{{appName}} — Amazon Pazar Analizi",
      "title_template": "%s | {{appName}}",
      "description": "{{appName}} ile Amazon kategorilerini analiz edin, pazar riskini ölçün ve doğru kararı alın.",
      "open_graph": {
        "type": "website",
        "images": ["/img/og-default.jpg"]
      },
      "twitter": {
        "card": "summary_large_image",
        "site": "",
        "creator": ""
      },
      "robots": {
        "noindex": false,
        "index": true,
        "follow": true
      }
    },
    "siteMetaByLocale": {
      "tr": {
        "title": "{{appName}} — Amazon Pazar Analizi ve Risk Skorlama",
        "description": "Keyword bazlı risk analizi, 5 boyutlu skorlama ve pazar verisiyle Amazon'da bilinçli karar alın.",
        "keywords": "{{appName}}, amazon analizi, pazar riski, keyword analizi, amazon fba, e-ticaret"
      },
      "en": {
        "title": "{{appName}} — Amazon Market Analysis & Risk Scoring",
        "description": "Keyword-based risk analysis, 5-dimensional scoring and market data for smart Amazon decisions.",
        "keywords": "{{appName}}, amazon analysis, market risk, keyword analysis, amazon fba, ecommerce"
      },
      "de": {
        "title": "{{appName}} — Amazon Marktanalyse & Risikobewertung",
        "description": "Keywordbasierte Risikoanalyse und Marktdaten für fundierte Amazon-Entscheidungen.",
        "keywords": "{{appName}}, amazon analyse, marktrisiko, keyword analyse, amazon fba"
      }
    },
    "localeDescriptionFallback": {
      "tr": "{{appName}} — Amazon kategori riski analizi ve pazar skorlama platformu.",
      "en": "{{appName}} — Amazon category risk analysis and market scoring platform.",
      "de": "{{appName}} — Amazon-Kategorierisikoanalyse und Marktbewertungsplattform."
    },
    "htmlMetaDescriptionByLocale": {
      "tr": "{{appName}} — Amazon'da doğru kategoriye girmeden önce riski ölçün.",
      "en": "{{appName}} — Measure the risk before entering an Amazon category.",
      "de": "{{appName}} — Messen Sie das Risiko, bevor Sie eine Amazon-Kategorie betreten."
    }
  },
  "jsonLd": {
    "organizationDescription": {
      "tr": "Amazon pazar analizi ve risk skorlama platformu.",
      "en": "Amazon market analysis and risk scoring platform.",
      "de": "Amazon-Marktanalyse- und Risikobewertungsplattform."
    },
    "placeholderSameAs": []
  },
  "editorial": {
    "teamNameTemplate": "{{appName}} Editorial Team"
  },
