# MarketPulse frontend — cp .env.example .env.local
# Backend: market_pulse/backend (8086)

NEXT_PUBLIC_API_URL=http://127.0.0.1:8086/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3077
NEXT_PUBLIC_DEFAULT_LOCALE=tr
NEXT_PUBLIC_APP_URL=http://localhost:3077

# Marka (bos birakilirsa src/config/site-defaults.json + DB site_settings)
NEXT_PUBLIC_APP_NAME=MarketPulse
NEXT_PUBLIC_APP_COPYRIGHT=MarketPulse
NEXT_PUBLIC_BRAND_WORD_MARK_LINE1=MarketPulse
NEXT_PUBLIC_BRAND_WORD_MARK_LINE2=
NEXT_PUBLIC_BRAND_TAGLINE=
NEXT_PUBLIC_BRAND_TAGLINE_EN=
NEXT_PUBLIC_LOGO_ALT=
NEXT_PUBLIC_ROOT_TITLE_DEFAULT=
NEXT_PUBLIC_ROOT_TITLE_TEMPLATE=
NEXT_PUBLIC_DEFAULT_HTML_DESCRIPTION=
NEXT_PUBLIC_PAGE_TITLE_SUFFIX_PATTERN=
NEXT_PUBLIC_MANIFEST_NAME=
NEXT_PUBLIC_MANIFEST_SHORT_NAME=
NEXT_PUBLIC_MANIFEST_DESCRIPTION=
NEXT_PUBLIC_MANIFEST_START_URL=/tr
NEXT_PUBLIC_JSONLD_PLACEHOLDER_SAME_AS=

# Opsiyonel: ornek e-posta placeholder, editoryal ekip, paylasim, analytics event isimleri, geri bildirim hedefi
NEXT_PUBLIC_SAMPLE_EMAIL_DOMAIN=example.com
NEXT_PUBLIC_EDITORIAL_TEAM_NAME=
NEXT_PUBLIC_SHARE_CARD_TAGLINE=
NEXT_PUBLIC_FEEDBACK_TARGET_ID=site
NEXT_PUBLIC_COOKIE_CONSENT_KEY_PREFIX=site
NEXT_PUBLIC_ANALYTICS_CONSENT_EVENT=site_consent_update
NEXT_PUBLIC_ANALYTICS_PAGE_VIEW_EVENT=site_page_view

NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_FACEBOOK_APP_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_REDIRECT_URI=http://localhost:3077/auth/apple/callback
BING_SITE_VERIFICATION=
INDEXNOW_KEY=
REVALIDATE_SECRET=
