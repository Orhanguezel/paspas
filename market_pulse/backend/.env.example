# App
APP_NAME=MarketPulse
APP_URL=https://marketpulse.domain.com
PORT=8086
NODE_ENV=development

# Ana DB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=mp_user
DB_PASSWORD=
DB_NAME=market_pulse_db
DB_ROOT_USER=app
DB_ROOT_PASSWORD=app

# Auth (zorunlu, default yok)
JWT_SECRET=
COOKIE_SECRET=

# Harici DB'ler (opsiyonel, okuma amaçlı)
EXTERNAL_DB_PASPAS_HOST=
EXTERNAL_DB_PASPAS_PORT=3306
EXTERNAL_DB_PASPAS_USER=
EXTERNAL_DB_PASPAS_PASSWORD=
EXTERNAL_DB_PASPAS_NAME=

# development: localhost:3096 (admin panel) env.ts ile otomatik eklenir; production icin tum originleri yazin
CORS_ORIGIN=http://localhost:3034,http://localhost:3000,http://localhost:3077,http://127.0.0.1:3077,http://localhost:3096,http://127.0.0.1:3096
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./uploads
LOCAL_STORAGE_BASE_URL=/uploads
PUBLIC_URL=http://localhost:8086
FRONTEND_URL=http://localhost:3077

# Seed admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_ID=4f618a8d-6fdb-498c-898a-395d368b2193
# Ikinci admin (seed: 001_auth_schema.sql) — ayni ADMIN_PASSWORD ile hash uretilir
ADMIN2_EMAIL=atakan07sahin@gmail.com
ADMIN2_ID=b8e4c2a1-9f0d-4e7b-8c6d-5a4b3c2d1e0f

# Observability
SENTRY_DSN=

# Storage: Cloudinary kullanilacaksa doldurun
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Harici DB parola sifreleme (017_external_db_connections tablosu icin)
# random uret: openssl rand -hex 32
DB_ENCRYPTION_KEY=

# E-posta — raporlama modulu icin (opsiyonel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
REPORT_EMAIL_TO=

# Lead Machine — Scraper Service (self-hosted, web scraping motoru)
SCRAPER_SERVICE_URL=http://localhost:8200
SCRAPER_SERVICE_API_KEY=
# Callback webhook imza dogrulama — openssl rand -hex 32 ile uret
SCRAPER_CALLBACK_SECRET=

# Lead Machine — Amazon (ayri servis, scraper-service TOS uyumsuz)
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# Lead Machine — AI
GROQ_API_KEY=
OPENAI_API_KEY=

# Lead Machine — Enrichment
APOLLO_API_KEY=

# Lead Machine — Fuar
TENTIMES_API_KEY=
WHRAI_API_KEY=
