{
  "name": "productspark-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "bun x tsc -p tsconfig.json && bun x tsc-alias -p tsconfig.json && node scripts/fix-esm-extensions.mjs",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "start:bun": "bun dist/index.js",
    "db:seed": "bun src/db/seed/index.ts",
    "db:seed:nodrop": "bun src/db/seed/index.ts --no-drop",
    "db:seed:only": "bun src/db/seed/index.ts --only=",
    "test": "bun test"
  },
  "dependencies": {
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/jwt": "^10",
    "@fastify/multipart": "^9",
    "@fastify/mysql": "^5.0.2",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5",
    "google-auth-library": "^10.4.1",
    "iyzipay": "^2.0.65",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.10",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@esbuild/linux-x64": "0.25.11",
    "@types/iyzipay": "^2.0.3",
    "@types/node": "20",
    "@types/nodemailer": "^7.0.3",
    "bun-types": "^1.3.1",
    "esbuild": "0.25.11",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "5"
  }
}
